‚îú‚îÄ‚îÄ ConstructApp.tsx        # package entry re-export only
‚îú‚îÄ‚îÄ catalog/                # documents, keys, manifest, document‚Üîdef converters
‚îÇ   ‚îú‚îÄ‚îÄ actors/              # ActorDocument type + parse/serialize/convert
‚îÇ   ‚îú‚îÄ‚îÄ props/               # PropDocument type + parse/serialize/convert
‚îÇ   ‚îú‚îÄ‚îÄ keys/                # CONSTRUCT_KEYS component key strings
‚îÇ   ‚îú‚îÄ‚îÄ manifest/            # KaykitManifest types, loader, tree filters, lookup helpers
‚îÇ   ‚îî‚îÄ‚îÄ slugify.ts            # shared document-id slugify helper
‚îú‚îÄ‚îÄ entities/                # factories, components, systems
‚îÇ   ‚îú‚îÄ‚îÄ editorCommon/         # shared origin marker, colliders, editableTarget, TRS, materials
‚îÇ   ‚îú‚îÄ‚îÄ actorEditor/          # actor root/character/attachment/collider spawn + systems
‚îÇ   ‚îú‚îÄ‚îÄ propEditor/           # prop root/part spawn + systems
‚îÇ   ‚îú‚îÄ‚îÄ gizmos/               # move/scale/rotate gizmo meshes, input, picking, system
